# Alibaba Cloud credentials (used by both aliyun CLI and Python SDK)
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret_here
ALIBABA_CLOUD_REGION_ID=cn-hangzhou

# =============================================================
# Optional: alicloud-redis-ops · 离线模式（专有云/无外网场景）
# =============================================================
# 用途：在 ECS 跳板机无法访问公网时，让脚本从你的内网 URL 下载 redis-cli。
# 何时需要：金融云、政务云、专有云、网闸隔离的生产环境。
# 阿里云 ECS + 公网通 → 不需要配置此项（脚本会自动用阿里云内网镜像源）。
# 完整说明：alicloud-redis-ops/references/redis-cli-install.md「用户配置指南」
#
# REDIS_CLI_BIN_URL=https://my-bucket.oss-cn-hangzhou-internal.aliyuncs.com/bin/redis-cli-7.2-musl-amd64
