#!/bin/bash
# DAS SDK 预编译脚本
# 目标: 将 das-20200116 SDK 预编译为二进制
# 输出: ~/.cache/aliyun-skills/bin/das-cli

SDK_VERSION="20200116"
CACHE_DIR="${HOME}/.cache/aliyun-skills"
BIN_DIR="${CACHE_DIR}/bin"
SDK_DIR="${CACHE_DIR}/sdk/das-${SDK_VERSION}"

# 创建目录
mkdir -p "${BIN_DIR}" "${SDK_DIR}"

# 下载 SDK (如未下载)
if [ ! -d "${SDK_DIR}/go.mod" ]; then
    go get github.com/aliyun/alibaba-cloud-sdk-go/sdk@latest
    go get github.com/aliyun/alibaba-cloud-das-sdk-go@v${SDK_VERSION}
fi

# 预编译
cd "${SDK_DIR}"
go build -buildmode=archive -o "${BIN_DIR}/das-sdk.a" ./...

# 编译 CLI wrapper
go build -ldflags="-s -w" -o "${BIN_DIR}/das-cli" ./cmd/das-cli

echo "DAS SDK 预编译完成: ${BIN_DIR}/das-cli"
echo "启动时间目标: <500ms (vs JIT 45s)"
