# Skill-internal report directories (P0-4 补漏)
# 忽略 reports/ 下所有非 templates/ 的内容 (reeporets 模板需保留)
# 例: alicloud-aiops-cruise/reports/perceive-2026.json (忽略)
#     alicloud-aiops-cruise/reports/templates/deep-report-template.md (保留)
alicloud-*/reports/*
!alicloud-*/reports/templates/
!alicloud-*/reports/templates/**

# ===== Runtime Data Root (Sprint 18) =====
# 统一运行时数据根目录 (默认 ${SKILLS_DIR}/.runtime, 可通过环境变量 ALIYUN_SKILLS_RUNTIME_ROOT 覆盖)
# 包含 baseline/audit/cache/logs/tmp 等子目录
.runtime/
.runtime-*/

# Legacy paths (Sprint 18 之前, 现在用软链接兼容 → .runtime/)
# 保留这些规则避免误提交历史数据
infra-baseline/
audit-results/

# Skill-internal runtime data (legacy; Sprint 19+ 将逐步迁移到 .runtime/)
alicloud-*/audit-results/
alicloud-*/scripts/audit-results/
alicloud-*/**/audit-results/

